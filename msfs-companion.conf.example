# MSFS 2024 Companion — LLM configuration
# --------------------------------------------------------------------------
# Copy this file to  msfs-companion.conf  (same folder) and edit the values.
# Both apps read it at startup, so you don't need Windows environment vars.
#
# Lines starting with # or ; are comments. Quotes around values are optional.
# A real OS environment variable, if set, overrides the matching line here.
# --------------------------------------------------------------------------

# Which LLM backend to use:  anthropic | openai | local
#   anthropic = Claude          (needs anthropic_api_key)
#   openai    = OpenAI          (needs openai_api_key)
#   local     = Ollama / LM Studio / llama.cpp — runs offline, no key
provider = openai

# Optional: pin a specific model. Leave commented for the provider default
# (anthropic -> claude-opus-4-8, openai -> gpt-4o, local -> llama3.1).
# model = gpt-4o

# Your API keys. Only the one for the chosen provider is needed.
openai_api_key = sk-REPLACE_ME
# anthropic_api_key = sk-ant-REPLACE_ME

# Optional: endpoint for the openai/local providers (OpenAI-compatible servers).
# The local default is http://localhost:11434/v1 (Ollama).
# base_url = http://localhost:11434/v1

# The controls app builds an AI-tailored setup automatically on launch and when
# you switch aircraft (default on). Set to false to only build it on the button.
# auto_setup = true

# Write the built setup straight into your matching MSFS input profiles
# (with a timestamped backup), for a fully hands-off setup. Default off because
# it changes real sim files. You still make manual changes with Learn mode and
# the Write dialog, and MSFS must be restarted (or the profile reselected) to
# load the changes.
# auto_write = true
