# Copy to .env and adjust. All optional — sane defaults are baked in.

# SimConnect caches each SimVar read for this many ms (lower = fresher, more CPU).
MSFS_SIMCONNECT_CACHE_MS=200

# Enable/disable each capability layer. Disable a layer you haven't set up
# so its tools report "disabled" instead of failing to import a dependency.
MSFS_ENABLE_SIMCONNECT=true
MSFS_ENABLE_FSUIPC=true
MSFS_ENABLE_MEMORY=false      # raw memory is OFF by default — opt in deliberately

# Raw-memory layer target. Process name is matched case-insensitively.
MSFS_PROCESS_NAME=FlightSimulator2024.exe

# Log level: DEBUG, INFO, WARNING, ERROR
MSFS_LOG_LEVEL=INFO
